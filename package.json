{
  "name": "campaign-template",
  "version": "0.1.0",
  "private": true,
  "description": "Law school election campaign starter powered by Payload CMS",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build:core": "next build && tsc -p tsconfig.json",
    "build:payload-admin": "PAYLOAD_CONFIG_PATH=dist/payload.config.js payload build",
    "build": "npm run build:core && npm run build:payload-admin",
    "build:railway": "npm run build:core && if [ \"${SKIP_PAYLOAD_ADMIN_BUILD:-0}\" = \"1\" ]; then echo \"Skipping Payload admin build\"; else npm run build:payload-admin; fi",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.next.json",
    "migrate:mongo": "bash scripts/migrate-local-to-production.sh",
    "migrate:all": "bash scripts/migrate-all-to-production.sh"
  },
  "dependencies": {
    "@payloadcms/bundler-webpack": "^1.0.9",
    "@payloadcms/db-mongodb": "^2.0.0",
    "@payloadcms/richtext-slate": "^1.5.2",
    "autoprefixer": "^10.4.20",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "next": "^15.2.4",
    "payload": "^2.17.2",
    "postcss": "^8.4.47",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.14"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=18.20.0"
  }
}
